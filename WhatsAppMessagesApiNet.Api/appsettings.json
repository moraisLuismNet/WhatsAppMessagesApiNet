{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DatabaseProvider": "SqlServer",
  "ConnectionStrings": {
    "SqlServer": "Server=W11P0RT;Database=WhatsAppMessagesApiNetDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True",
    "MySql": "Server=localhost;Database=WhatsAppMessagesApiNet;User=root;Password=root;",
    "PostgreSql": "Host=localhost;Database=WhatsAppMessagesApiNet;Username=postgres;Password=postgres;",
    "Sqlite": "Data Source=WhatsAppMessagesApiNet.db",
    "MongoDb": "mongodb://localhost:27017"
  },
  "MongoDbSettings": {
    "DatabaseName": "WhatsAppMessagesApiNet"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "WhatsAppMessagesApiNet",
    "Audience": "WhatsAppMessagesApiNetClient",
    "ExpirationHours": "8"
  },
  "WhatsAppProviders": {
    "Default": "Twilio",
    "Twilio": {
      "AccountSid": "",
      "AuthToken": "",
      "FromNumber": ""
    },
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/whatsappapi-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  }
}
